# Personal Net Worth Tracker — local development

DATABASE_URL=postgresql://pfsm_user:pfsm_password@localhost:5432/personal_finance_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=personal_finance_db
DB_USER=pfsm_user
DB_PASSWORD=pfsm_password

NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Optional local LLM analysis via Ollama (all processing stays on-device).
# Enable the "llm" docker compose profile and set LLM_ENABLED=true to use it.
LLM_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
# Context window (tokens). Raised from Ollama's 2048 default so the full
# database record dump fits when the assistant answers follow-up questions.
OLLAMA_NUM_CTX=8192
